{
  "name": "minimemory-service",
  "version": "0.1.0",
  "description": "Agentic memory service - serverless vector database with memory APIs",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "deploy": "wrangler deploy",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "memory",
    "vector-database",
    "rag",
    "ai",
    "agents",
    "embeddings",
    "semantic-search"
  ],
  "author": "Mauricio Perera",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.6.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.11.1",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.16",
    "wrangler": "^3.91.0"
  }
}
