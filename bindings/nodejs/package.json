{
  "name": "minimemory",
  "version": "0.1.0",
  "description": "Embedded vector database for Node.js - like SQLite for vectors",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "minimemory",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-musl"
      ]
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minimemory/minimemory"
  },
  "keywords": [
    "vector",
    "database",
    "embedding",
    "similarity",
    "search",
    "hnsw",
    "napi-rs",
    "rust"
  ],
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "typescript": "^5.3.0"
  },
  "scripts": {
    "build": "napi build --platform --release --features nodejs",
    "build:debug": "napi build --platform --features nodejs",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node test.js"
  },
  "engines": {
    "node": ">= 14"
  }
}
