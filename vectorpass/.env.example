# VectorPass Environment Variables
# Copy this file to .env and fill in your values

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# Email Service Configuration
# Options: log (dev only), resend, sendgrid, mailgun
EMAIL_SERVICE=log
EMAIL_API_KEY=your_email_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# Mailgun (only if EMAIL_SERVICE=mailgun)
MAILGUN_DOMAIN=mg.yourdomain.com

# Cloudflare KV Namespace IDs
# Create with: wrangler kv:namespace create <NAME>
USERS_KV_ID=your_users_kv_namespace_id
VECTORS_KV_ID=your_vectors_kv_namespace_id
RATE_LIMITS_KV_ID=your_rate_limits_kv_namespace_id
